### Create Baggage Data
POST {{baseUrl}}/baggages
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "name": "trousers"
}

### Get all baggages
GET {{baseUrl}}/baggages
Authorization: Bearer {{token}}

### Get a specific baggage
GET {{baseUrl}}/baggages/{{baggageId}}
Authorization: Bearer {{token}}

### update a specific baggage
PATCH {{baseUrl}}/baggages/{{baggageId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "name": "T Shirt",
    "completed": true
}

### Delete a specific baggage
DELETE  {{baseUrl}}/baggages/{{baggageId}}
Authorization: Bearer {{token}}

### create a user
POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "name": "Test User",
    "email": "user@test.com",
    "password": "abcdefgh"
}

### Get all users
GET {{baseUrl}}/users
Authorization: Bearer {{token}}

### Get specific user
GET {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{token}}

### update a user
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "email": "user@test2.com"
}

### Delete specific user
DELETE {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{token}}

### register a user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "name": "Test User",
    "email": "user@test.com",
    "password": "abcdefgh"
}

### login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
